rules_version = '2';

// PLACEHOLDER — reglas de Storage.
// Se completan cuando se implemente el primer flujo que sube fotos
// (probablemente F1.2 con la foto de portada del viaje).

service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
