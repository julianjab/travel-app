---
// BaseLayout.astro — shared HTML shell with <head>, OG meta, and footer.
// All user-facing strings are in Spanish (voseo).

import '../styles/global.css';

export interface Props {
  title: string;
  description: string;
  ogImage?: string;
  ogUrl?: string;
  noIndex?: boolean;
}

const {
  title,
  description,
  ogImage = 'https://vamos.app/og-image.png',
  ogUrl = Astro.url.href,
  noIndex = false,
} = Astro.props;

const canonicalUrl = ogUrl;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary meta -->
    <title>{title}</title>
    <meta name="description" content={description} />
    {noIndex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Vamos" />
    <meta property="og:locale" content="es" />

    <!-- Twitter / X card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Preconnect for Inter font from Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="min-h-screen flex flex-col">
    <slot />

    <footer class="mt-auto py-6 text-center text-sm text-gray-400">
      <p>© {new Date().getFullYear()} Vamos. Planificá tus viajes en grupo.</p>
    </footer>
  </body>
</html>
