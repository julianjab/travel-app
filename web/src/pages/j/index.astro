---
// j/index.astro — Invite page for /j/{inviteCode}
// Served as a static shell for all /j/* paths via Firebase Hosting rewrite.
// The invite code is extracted from window.location.pathname at runtime.
// Static HTML + client-side fetch. No SSR. No auth. Read-only.
// Metadata is generic — trips are private, don't expose content to crawlers.
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Te invitaron a un viaje — Vamos"
  description="Abrí el link para ver el viaje y unirte desde la app Vamos."
  noIndex={true}
>
  <main class="flex flex-col items-center justify-center flex-1 px-4 py-16">
    <!-- Loading state — shown initially, hidden once data loads -->
    <div id="state-loading" class="flex flex-col items-center gap-4 text-center">
      <div
        class="w-12 h-12 rounded-full border-4 border-amber-200 border-t-amber-500 animate-spin"
        aria-label="Cargando..."
        role="status"
      ></div>
      <p class="text-gray-500 text-sm">Cargando invitación...</p>
    </div>

    <!-- Trip card — hidden initially, shown when invite resolves OK -->
    <div id="state-trip" class="hidden w-full max-w-sm">
      <!-- Trip gradient cover (placeholder — no Storage in MVP) -->
      <div
        class="w-full h-40 rounded-2xl mb-6 bg-gradient-to-br from-amber-400 to-orange-500 flex items-end p-5"
        aria-hidden="true"
      >
        <!-- Destination pill -->
        <span
          id="trip-destination-pill"
          class="inline-block bg-white/20 backdrop-blur-sm text-white text-sm font-medium px-3 py-1 rounded-full"
        ></span>
      </div>

      <!-- Trip metadata -->
      <div class="text-center mb-8">
        <p class="text-sm text-gray-500 mb-1">Te invitaron a</p>
        <h1 id="trip-name" class="text-2xl font-bold text-gray-900 leading-tight"></h1>
        <p id="trip-dates" class="mt-2 text-gray-500 text-sm"></p>
      </div>

      <!-- Primary CTA — deep link to app -->
      <a
        id="cta-open-app"
        href="#"
        class="block w-full text-center py-4 rounded-2xl bg-amber-500 text-white font-semibold text-base hover:bg-amber-600 transition-colors"
      >
        Abrir en Vamos
      </a>

      <!-- Secondary CTA — app stores (for users who don't have the app) -->
      <div class="mt-6 text-center">
        <p class="text-sm text-gray-400 mb-3">¿No tenés la app? Descargala</p>
        <div class="flex flex-col sm:flex-row gap-3 justify-center">
          <a
            href="https://apps.apple.com"
            class="inline-flex items-center justify-center gap-2 px-5 py-2.5 rounded-xl border border-gray-200 text-gray-700 text-sm font-medium hover:bg-gray-50 transition-colors"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Descargar Vamos en App Store"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
            </svg>
            App Store
          </a>
          <a
            href="https://play.google.com"
            class="inline-flex items-center justify-center gap-2 px-5 py-2.5 rounded-xl border border-gray-200 text-gray-700 text-sm font-medium hover:bg-gray-50 transition-colors"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Descargar Vamos en Google Play"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M3 20.5v-17c0-.83.94-1.3 1.6-.8l14 8.5c.6.37.6 1.23 0 1.6l-14 8.5c-.66.5-1.6.03-1.6-.8z"/>
            </svg>
            Google Play
          </a>
        </div>
      </div>
    </div>

    <!-- Error: invite revoked -->
    <div id="state-revoked" class="hidden text-center max-w-xs">
      <div class="text-5xl mb-4" role="img" aria-label="Candado">🔒</div>
      <h1 class="text-xl font-semibold text-gray-800">Este link ya no está disponible.</h1>
      <p class="mt-2 text-gray-500 text-sm">
        El link de invitación fue desactivado. Pedile al organizador un link nuevo.
      </p>
    </div>

    <!-- Error: invite not found or trip missing -->
    <div id="state-not-found" class="hidden text-center max-w-xs">
      <div class="text-5xl mb-4" role="img" aria-label="Lupa">🔍</div>
      <h1 class="text-xl font-semibold text-gray-800">Link inválido.</h1>
      <p class="mt-2 text-gray-500 text-sm">
        No encontramos este link de invitación. Verificá que sea correcto.
      </p>
    </div>

    <!-- Error: generic (network / unexpected) -->
    <div id="state-error" class="hidden text-center max-w-xs">
      <div class="text-5xl mb-4" role="img" aria-label="Advertencia">⚠️</div>
      <h1 class="text-xl font-semibold text-gray-800">Algo salió mal.</h1>
      <p class="mt-2 text-gray-500 text-sm">
        No pudimos cargar la invitación. Revisá tu conexión e intentá de nuevo.
      </p>
      <button
        id="btn-retry"
        class="mt-4 px-5 py-2.5 rounded-xl bg-amber-500 text-white text-sm font-medium hover:bg-amber-600 transition-colors"
        type="button"
      >
        Reintentar
      </button>
    </div>
  </main>
</BaseLayout>

<script>
  // Client-side invite resolution.
  // The invite code is extracted from the URL path: /j/{code}
  // Firebase SDK is imported dynamically to keep the initial HTML lean.

  import { resolveInvite } from '../../lib/firebase';

  /**
   * Extracts the invite code from the URL path.
   * Path format: /j/{code}
   */
  function getInviteCodeFromPath(): string {
    const segments = window.location.pathname.split('/').filter(Boolean);
    // segments[0] === 'j', segments[1] === code
    return segments[1] ?? '';
  }

  /**
   * Shows one state panel and hides all others.
   */
  function showState(stateId: string): void {
    const states = ['state-loading', 'state-trip', 'state-revoked', 'state-not-found', 'state-error'];
    for (const id of states) {
      const el = document.getElementById(id);
      if (el) {
        el.classList.toggle('hidden', id !== stateId);
      }
    }
  }

  /**
   * Formats two Firestore Timestamps to "12 jun – 5 jul 2026".
   * Firestore Timestamp objects support .toDate().
   */
  function formatDateRange(start: { toDate(): Date }, end: { toDate(): Date }): string {
    const startDate = start.toDate();
    const endDate = end.toDate();

    const months = ['ene', 'feb', 'mar', 'abr', 'may', 'jun', 'jul', 'ago', 'sep', 'oct', 'nov', 'dic'];

    const startDay = startDate.getDate();
    const startMonth = months[startDate.getMonth()];
    const endDay = endDate.getDate();
    const endMonth = months[endDate.getMonth()];
    const endYear = endDate.getFullYear();

    if (
      startDate.getMonth() === endDate.getMonth() &&
      startDate.getFullYear() === endDate.getFullYear()
    ) {
      return `${startDay} – ${endDay} ${endMonth} ${endYear}`;
    }

    return `${startDay} ${startMonth} – ${endDay} ${endMonth} ${endYear}`;
  }

  /**
   * Populates the trip card DOM elements with resolved invite data.
   */
  function populateTripCard(data: { invite: { tripId: string }; trip: { name: string; destination: string; startDate: { toDate(): Date }; endDate: { toDate(): Date } } }, code: string): void {
    const { trip } = data;

    const nameEl = document.getElementById('trip-name');
    const datesEl = document.getElementById('trip-dates');
    const destinationPillEl = document.getElementById('trip-destination-pill');
    const ctaEl = document.getElementById('cta-open-app');

    if (nameEl) nameEl.textContent = trip.name;
    if (destinationPillEl) destinationPillEl.textContent = trip.destination;
    if (datesEl) datesEl.textContent = formatDateRange(trip.startDate, trip.endDate);
    if (ctaEl) (ctaEl as HTMLAnchorElement).href = `vamos://join/${code}`;
  }

  async function loadInvite(): Promise<void> {
    showState('state-loading');

    const code = getInviteCodeFromPath();

    if (!code) {
      showState('state-not-found');
      return;
    }

    try {
      const result = await resolveInvite(code);

      if (result.ok) {
        populateTripCard(result.data, code);
        showState('state-trip');
      } else {
        switch (result.error) {
          case 'revoked':
            showState('state-revoked');
            break;
          case 'not_found':
          case 'trip_not_found':
            showState('state-not-found');
            break;
          default:
            showState('state-error');
        }
      }
    } catch (err) {
      console.error('[vamos] Failed to resolve invite:', err);
      showState('state-error');
    }
  }

  // Retry button
  document.getElementById('btn-retry')?.addEventListener('click', () => { loadInvite(); });

  // Kick off on page load
  loadInvite();
</script>
