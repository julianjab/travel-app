---
// index.astro — MVP placeholder home.
// Real marketing copy enters post-Case 0.
import BaseLayout from '../layouts/BaseLayout.astro';

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      name: 'Vamos',
      url: 'https://vamos.app',
      description: 'App para planear viajes en grupo en LATAM.',
    },
    {
      '@type': 'WebApplication',
      name: 'Vamos',
      url: 'https://vamos.app',
      applicationCategory: 'TravelApplication',
      operatingSystem: 'iOS, Android',
      description:
        'Vamos es la app para planear y ejecutar viajes en grupo. Itinerario colaborativo, gastos compartidos y links de invitación por WhatsApp.',
      offers: {
        '@type': 'Offer',
        price: '0',
        priceCurrency: 'USD',
      },
    },
  ],
};
---

<BaseLayout
  title="Vamos — Planificá tus viajes en grupo"
  description="Vamos es la app para planear y ejecutar viajes en grupo. Itinerario colaborativo, gastos compartidos y links de invitación por WhatsApp."
>
  <!-- JSON-LD for organization and web application -->
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <main class="flex flex-col items-center justify-center flex-1 px-4 py-20 text-center">
    <!-- Logo / wordmark placeholder -->
    <div class="mb-8">
      <span class="text-4xl font-bold tracking-tight text-gray-900">Vamos</span>
      <span class="text-4xl font-bold tracking-tight text-amber-500">.</span>
    </div>

    <h1 class="text-2xl font-semibold text-gray-800 max-w-md leading-snug">
      La app para planear viajes en grupo sin dramas.
    </h1>

    <p class="mt-4 text-gray-500 max-w-sm">
      Itinerario colaborativo, gastos compartidos y un link de WhatsApp para que todos entren.
    </p>

    <!-- Store CTAs -->
    <div class="mt-10 flex flex-col sm:flex-row gap-4">
      <a
        href="https://apps.apple.com"
        class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-xl bg-gray-900 text-white font-medium hover:bg-gray-700 transition-colors"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Descargar Vamos en App Store"
      >
        <!-- Apple icon (inline SVG — avoids extra asset) -->
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
        </svg>
        App Store
      </a>
      <a
        href="https://play.google.com"
        class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-xl bg-amber-500 text-white font-medium hover:bg-amber-600 transition-colors"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Descargar Vamos en Google Play"
      >
        <!-- Play icon (inline SVG) -->
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M3 20.5v-17c0-.83.94-1.3 1.6-.8l14 8.5c.6.37.6 1.23 0 1.6l-14 8.5c-.66.5-1.6.03-1.6-.8z"/>
        </svg>
        Google Play
      </a>
    </div>
  </main>
</BaseLayout>
